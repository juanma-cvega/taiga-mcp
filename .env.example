TAIGA_URL=https://api.taiga.io/api/v1
TAIGA_USERNAME=your_username
TAIGA_PASSWORD=your_password

# Optional: web-UI base URL used to build the verification links returned by
# the create/update tools. Derived from TAIGA_URL if unset (api.taiga.io maps
# to tree.taiga.io; self-hosted drops the /api/v1 suffix).
# TAIGA_UI_URL=https://tree.taiga.io

# Optional: point the smoke test at a throwaway project for the full
# create/get/update lifecycle (scripts/smoke_test.py). Read-only if unset.
TAIGA_SMOKE_PROJECT_SLUG=your-smoke-project

# --- Smoke test credentials (scripts/smoke_test.py) ---
# The smoke test authenticates separately from the MCP server so it can target
# a throwaway project on a different account. These are required (no fallback
# to the TAIGA_* values above).
TAIGA_SMOKE_URL=https://api.taiga.io/api/v1
TAIGA_SMOKE_USERNAME=your_smoke_username
TAIGA_SMOKE_PASSWORD=your_smoke_password
